{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Backend",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/hospital-management-system/backend"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start Frontend",
            "type": "shell",
            "command": "npm start",
            "options": {
                "cwd": "${workspaceFolder}/hospital-management-system/client"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start Both Servers",
            "dependsOn": [
                "Start Backend",
                "Start Frontend"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
